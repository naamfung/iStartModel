# 忽略指定名字文件
CODE_OF_CONDUCT.*
EasyPlayer*.*
lines.sh
demo.html
easypalyer.html
.hintrc

# Test binary, build with `go test -c`
*.test
*.prof
*.cover

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# 忽略日志文件
*.log
logs/

# 忽略临时文件
*.tmp
*.apk.sha1
*.swp
*.swo

# 忽略IDE生成的文件
garplayer
.vscode/
.idea/
.trae/
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/

# 忽略数据和缓存目录
backup/
uploads/
docs/
bak/
tmp/
temp/
.cache/

# 忽略依赖目录
vendor/
node_modules/

# 忽略操作系统文件
.DS_Store
Thumbs.db

# 忽略数据库文件
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-shm
*.db-wal

# 忽略会话文件
content/session/

# 忽略Docker相关临时文件
Dockerfile.*
.dockerignore

# 忽略Lua插件编译产物
*.luac

# 忽略 agent 文档
AGENTS.md

